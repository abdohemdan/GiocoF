<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee                              https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <welcome-file-list>
        <welcome-file>GIOCO.html</welcome-file>
    </welcome-file-list>
    <servlet>
        <servlet-name>SaveMapServlet</servlet-name>
        <servlet-class>SaveMapServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LoadMapServlet</servlet-name>
        <servlet-class>LoadMapServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DeleteMapServlet</servlet-name>
        <servlet-class>DeleteMapServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SalvaScoreServlet</servlet-name>
        <servlet-class>SalvaScoreServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>RegisterServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>LogoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>GoogleLoginServlet</servlet-name>
        <servlet-class>GoogleLoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>GoogleCallbackServlet</servlet-name>
        <servlet-class>GoogleCallbackServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SessionServlet</servlet-name>
        <servlet-class>SessionServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CambiaNickNameServlet</servlet-name>
        <servlet-class>CambiaNickNameServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SaveMapServlet</servlet-name>
        <url-pattern>/SalvaMappaPersonalizzata</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LoadMapServlet</servlet-name>
        <url-pattern>/CaricaMappePersonalizzate</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DeleteMapServlet</servlet-name>
        <url-pattern>/EliminaMappaPersonalizzata</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SalvaScoreServlet</servlet-name>
        <url-pattern>/Score</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/Register</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/Logout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>GoogleLoginServlet</servlet-name>
        <url-pattern>/GoogleLogin</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>GoogleCallbackServlet</servlet-name>
        <url-pattern>/GoogleCallback</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SessionServlet</servlet-name>
        <url-pattern>/Session</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CambiaNickNameServlet</servlet-name>
        <url-pattern>/CambiaNickname</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
</web-app>
